from functools import cmp_to_key

class Solution:
    def largestNumber(self, nums: List[int]) -> str:
        nums = sorted(map(str, nums), key=cmp_to_key(lambda a, b: (b+a > a+b) - (b+a < a+b)))
        return str(int(''.join(nums)))

