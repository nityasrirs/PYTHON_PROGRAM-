class Solution:
    def toHex(self, num: int) -> str:
        if num == 0:
            return "0"

        if num < 0:
            num += 2 ** 32

        hex_chars = "0123456789abcdef"
        res = ""

        while num:
            res = hex_chars[num % 16] + res
            num //= 16

        return res
